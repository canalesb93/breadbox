package components

// ReportsSkeleton renders a placeholder mirroring the layout of the
// /reports inbox page — page header, filter tabs ("All / Unread / Read"
// + "Mark all read"), and a daisy `list` of message rows. Each row
// mirrors ReportInboxRow: a square priority tile, a headline line, a
// one-line body-preview, and a quiet meta line. Sized to match the real
// component so a future swap-in (filter switch, AJAX refresh, dashboard
// inbox preview) doesn't shift layout.
//
// /reports is a full-SSR page today; this primitive is exposed in
// /design#loading so it's ready for the eventual AJAX swap and
// discoverable to anyone wiring loading states for adjacent
// agent-reports surfaces.
//
// Uses the daisy `skeleton` primitive (per .claude/rules/daisyui.md, the
// hand-rolled `bb-skeleton*` family is being retired).
templ ReportsSkeleton() {
	<div aria-hidden="true">
		<!-- Page header: title + subtitle + "Manage format" link slot -->
		<div class="bb-page-header">
			<div class="space-y-2">
				<div class="skeleton h-7 w-44 rounded-md"></div>
				<div class="skeleton h-3 w-80 hidden sm:block"></div>
			</div>
			<div class="flex items-center gap-2">
				<div class="skeleton h-8 w-32 rounded-md"></div>
			</div>
		</div>
		<!-- Filter tabs + mark-all-read -->
		<div class="flex items-center justify-between gap-2 mb-5">
			<div class="flex items-center gap-4">
				<div class="skeleton h-5 w-12"></div>
				<div class="skeleton h-5 w-16"></div>
				<div class="skeleton h-5 w-12"></div>
			</div>
			<div class="skeleton h-8 w-28 rounded-md shrink-0"></div>
		</div>
		<!-- Inbox list. Widths vary so the skeleton reads as motion. -->
		<ul class="list rounded-xl bg-base-100 border border-base-300 overflow-hidden">
			@reportsSkeletonRow("w-72 sm:w-96", "w-56", true)
			@reportsSkeletonRow("w-56 sm:w-72", "w-64", false)
			@reportsSkeletonRow("w-80 sm:w-[28rem]", "w-48", true)
			@reportsSkeletonRow("w-64 sm:w-80", "w-60", false)
			@reportsSkeletonRow("w-72 sm:w-[26rem]", "w-52", true)
			@reportsSkeletonRow("w-52 sm:w-72", "w-44", false)
		</ul>
	</div>
}

// reportsSkeletonRow mirrors one ReportInboxRow: a square leading tile,
// a headline line, a one-line preview, and a meta line (author + time +
// a tag chip). `unread` reserves the trailing mark-read button slot.
templ reportsSkeletonRow(titleW string, previewW string, unread bool) {
	<li class="list-row items-center">
		<div class="skeleton w-10 h-10 rounded-lg shrink-0"></div>
		<div class="min-w-0 space-y-1.5">
			<div class={ "skeleton h-4 rounded-md max-w-full", titleW }></div>
			<div class={ "skeleton h-3 rounded-md max-w-full", previewW }></div>
			<div class="flex items-center gap-2">
				<div class="skeleton h-3 w-20 rounded-md"></div>
				<div class="skeleton h-3 w-12 rounded-md"></div>
				<div class="skeleton h-3 w-10 rounded-full"></div>
			</div>
		</div>
		<div class="shrink-0 self-center">
			if unread {
				<div class="skeleton h-6 w-6 rounded"></div>
			}
		</div>
	</li>
}
