package components

// SettingsSectionProps controls the shared section container used by
// every /settings/* tab. See .claude/rules/settings.md for the design
// rules — this is the single approved section shape inside the
// Settings modal.
//
// A section is a quiet, lightly-bordered container with a header row
// and a body of rows separated by hairline dividers. The header is
// `[icon? + title + caption?]` on the left and an optional `Right`
// templ.Component on the right (for a primary action button — never a
// status badge; surface those inline within a SettingsRow instead).
//
// Variant tints the section for special-case visuals:
//   - "" (default) — neutral, base-300 border
//   - "danger"     — error-tinted border + error-tinted icon (use for
//                    destructive sections like "Danger zone")
type SettingsSectionProps struct {
	Icon string
	// BrandIcon, when set, replaces Icon with a vendored brand SVG
	// (see brand.templ). Monochrome brand marks inherit the same
	// muted icon color the Lucide path uses; multi-color marks
	// (Teller) render in brand colors.
	BrandIcon string
	Title     string
	Caption   string
	Right     templ.Component
	Variant   string
	// FullWidth drops the left gutter so the content spans the whole
	// width (overview cards, stats grids, page-level alerts). When set,
	// the content is NOT auto-carded — the caller supplies its own
	// container.
	FullWidth bool
	// Bare renders the children directly in the content column without
	// the default card wrapper — for action lists or sections that manage
	// their own cards (e.g. the API-keys list + reveal).
	Bare bool
	// Form wraps the children in a <form> so a single in-section Save
	// button (use the Footer slot) submits all of its rows at once.
	// Omit for sections that hold auto-save rows only — those wrap
	// each row in its own form via SettingsAutoSaveForm.
	Form *SettingsSectionFormProps
	// Footer optionally renders a row pinned to the bottom of the
	// section — typically a `bb-action-row` carrying the Save button
	// for a multi-input section form. Renders below the body with a
	// shared border-top so it reads as part of the section, not
	// floating beneath it.
	Footer templ.Component
}

// SettingsSectionFormProps describes the <form> wrapper opt-in. Action
// must be a server-side POST endpoint that handles the section's
// inputs together.
type SettingsSectionFormProps struct {
	Action    string
	Enctype   string // empty → no enctype attribute (default form encoding)
	CSRFToken string
	// Extra holds arbitrary attributes for the form (x-data, autocomplete, etc.).
	Extra templ.Attributes
}

// SettingsSection is the canonical wrapper — a borderless two-column
// group. The section identity (icon + title + caption) renders in the
// left gutter; the body slot (one or more SettingsRow calls) + the
// optional Right action + Footer render in the right content column.
// See .claude/rules/settings.md.
templ SettingsSection(p SettingsSectionProps) {
	if p.Form != nil {
		<form
			method="POST"
			action={ templ.SafeURL(p.Form.Action) }
			if p.Form.Enctype != "" {
				enctype={ p.Form.Enctype }
			}
			class={ settingsSectionClasses(p.Variant, p.FullWidth) }
			{ p.Form.Extra... }
		>
			if p.Form.CSRFToken != "" {
				<input type="hidden" name="_csrf" value={ p.Form.CSRFToken }/>
			}
			@settingsSectionGrid(p) {
				{ children... }
			}
		</form>
	} else {
		<section class={ settingsSectionClasses(p.Variant, p.FullWidth) }>
			@settingsSectionGrid(p) {
				{ children... }
			}
		</section>
	}
}

// settingsSectionGrid lays out the gutter + content. The content is
// wrapped in a card by default; Bare/FullWidth render children directly so
// the caller controls the container. The Right action sits above the card;
// the Footer (Save bar) sits inside it.
templ settingsSectionGrid(p SettingsSectionProps) {
	<div class="bb-settings-section__grid">
		if !p.FullWidth {
			@settingsSectionMeta(p)
		}
		<div class="bb-settings-section__content">
			if p.Right != nil {
				<div class="bb-settings-section__action">
					@p.Right
				</div>
			}
			if p.Bare || p.FullWidth {
				{ children... }
				if p.Footer != nil {
					<div class="bb-settings-section__footer">
						@p.Footer
					</div>
				}
			} else {
				<div class={ settingsCardClasses(p.Variant) }>
					{ children... }
					if p.Footer != nil {
						<div class="bb-settings-card__footer">
							@p.Footer
						</div>
					}
				</div>
			}
		</div>
	</div>
}

// settingsSectionMeta renders the left gutter. The heading block is only
// emitted when a Title exists; the gutter element itself is always
// present so the content column keeps a consistent left edge across
// every section — the editorial alignment that makes the borderless
// layout read as one surface rather than a stack of cards.
templ settingsSectionMeta(p SettingsSectionProps) {
	<div class="bb-settings-section__meta">
		if p.Title != "" {
			<div class="bb-settings-section__heading">
				if p.BrandIcon != "" {
					@BrandIcon(p.BrandIcon, settingsSectionIconClasses(p.Variant))
				} else if p.Icon != "" {
					<i data-lucide={ p.Icon } class={ settingsSectionIconClasses(p.Variant) }></i>
				}
				<h2 class="bb-settings-section__title">{ p.Title }</h2>
			</div>
			if p.Caption != "" {
				<p class="bb-settings-section__caption">{ p.Caption }</p>
			}
		}
	</div>
}

func settingsSectionClasses(variant string, fullWidth bool) string {
	out := "bb-settings-section"
	if variant == "danger" {
		out += " bb-settings-section--danger"
	}
	if fullWidth {
		out += " bb-settings-section--full"
	}
	return out
}

func settingsCardClasses(variant string) string {
	if variant == "danger" {
		return "bb-settings-card bb-settings-card--danger"
	}
	return "bb-settings-card"
}

// SettingsCardProps configures a standalone content card — the same subtle
// container SettingsSection wraps its content in, exposed for Bare sections
// that hold several cards or a card with its own header (Title + Caption +
// optional Right slot) and Footer.
type SettingsCardProps struct {
	Title   string
	Caption string
	Variant string
	Right   templ.Component
	Footer  templ.Component
}

templ SettingsCard(p SettingsCardProps) {
	<div class={ settingsCardClasses(p.Variant) }>
		if p.Title != "" {
			<div class="bb-settings-card__header flex items-start justify-between gap-3">
				<div class="min-w-0">
					<div class="bb-settings-card__title">{ p.Title }</div>
					if p.Caption != "" {
						<p class="bb-settings-card__caption">{ p.Caption }</p>
					}
				</div>
				if p.Right != nil {
					<div class="shrink-0">
						@p.Right
					</div>
				}
			</div>
		}
		{ children... }
		if p.Footer != nil {
			<div class="bb-settings-card__footer">
				@p.Footer
			</div>
		}
	</div>
}

func settingsSectionIconClasses(variant string) string {
	switch variant {
	case "danger":
		return "w-4 h-4 text-error shrink-0"
	default:
		return "w-4 h-4 text-base-content/45 shrink-0"
	}
}
