package pages

import (
	"strconv"
	"time"

	"breadbox/internal/templates/components"
)

// AgentRunDetail renders the per-run page at /agents/runs/{shortId}.
//
// Layout, top-down:
//
//	┌────────────────────────────────────────────────────┐
//	│ Breadcrumbs                                        │
//	├──── sticky header ─────────────────────────────────┤
//	│ ← agent · shortid · status · duration · re-run     │
//	├──────────────┬─────────────────────────────────────┤
//	│ Transcript   │ Side panel                          │
//	│ (chat thread)│ - Usage / cost stats                │
//	│              │ - Operator note (inline edit)       │
//	│              │ - Reports produced                  │
//	│              │ - Prompt detail (system/user/prefix)│
//	└──────────────┴─────────────────────────────────────┘
//
// Live updates: when the run is in_progress, an Alpine factory
// (`agentRunDetail`) polls `GET /-/agents/runs/{shortId}/live` every
// 3 s and patches the transcript + stats panel HTML in-place. We no
// longer emit `<meta http-equiv="refresh">` — full-page reloads kill
// scroll position and any open <details> nodes.
templ AgentRunDetail(p AgentRunDetailProps) {
	<!-- CDN dependencies for the shared markdown renderer + the
	     run-detail Alpine factory. Synchronous loads (no defer) so
	     Alpine.data() registration runs before alpine:init. Mirrors
	     the convention used by /reports/{id} and the transaction
	     activity timeline. -->
	<script src="https://cdn.jsdelivr.net/npm/marked@15.0.12/marked.min.js" integrity="sha384-948ahk4ZmxYVYOc+rxN1H2gM1EJ2Duhp7uHtZ4WSLkV4Vtx5MUqnV+l7u9B+jFv+" crossorigin="anonymous"></script>
	<script src="https://cdn.jsdelivr.net/npm/dompurify@3.4.0/dist/purify.min.js" integrity="sha384-lExbHoPFNjOW+xMze1tJWzpODN3bi/yx3zhbwRoZWaIYxjl89HxJcI2BxPTNa9M7" crossorigin="anonymous"></script>
	<script src="/static/js/admin/markdown.js"></script>
	<script src="/static/js/admin/components/agent_run_detail.js"></script>
	<div
		x-data="agentRunDetail"
		data-run-short-id={ p.Run.ShortID }
		data-run-status={ p.Run.Status }
		data-started-at={ p.Run.StartedAt.Format(time.RFC3339Nano) }
		data-poll-seconds={ pollSeconds(p) }
		x-init="$store.shortcuts.setScope('agent-run-detail'); init()"
		x-destroy="$store.shortcuts.setScope('global')"
	>
		@components.BreadcrumbNav(agentRunDetailBreadcrumbs(p))
		@agentRunDetailHeader(p)
		if p.Run.Status == "error" && p.Run.ErrorMessage != "" {
			@agentRunErrorAlert(p.Run)
		}
		if p.Error != "" {
			<div class="alert alert-warning alert-soft mb-4">
				<i data-lucide="triangle-alert" class="w-4 h-4"></i>
				<span>{ p.Error }</span>
			</div>
		}
		<div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_22rem] gap-4 items-start">
			<section class="min-w-0">
				@agentRunTranscriptCard(p)
			</section>
			<aside class="bb-run-aside space-y-4">
				@agentRunStatsCard(p)
				@agentRunToolsCard(p)
				@agentRunNoteCard(p)
				if len(p.Run.Reports) > 0 {
					@agentRunReportsCard(p)
				}
				if p.TranscriptPath != "" {
					@agentRunTranscriptPathCard(p)
				}
			</aside>
		</div>
	</div>
}

// agentRunDetailHeader is the sticky top strip — agent identity, status,
// shortid, live duration ticker, and the "Re-run" action. Replaces the
// old bb-page-header because the run-detail page wants tighter
// information density (status next to shortid, no big H1).
templ agentRunDetailHeader(p AgentRunDetailProps) {
	<div class="bb-run-header">
		<div class="bb-run-header__lead">
			<a href={ templ.SafeURL(agentRunHeaderBackHref(p)) } class="btn btn-ghost btn-sm btn-square" title="Back to runs">
				<i data-lucide="arrow-left" class="w-4 h-4"></i>
			</a>
			<div class="bb-run-header__icon">
				<i data-lucide="bot" class="w-4 h-4"></i>
			</div>
			<div class="min-w-0">
				<div class="flex items-center gap-2 flex-wrap">
					if p.Run.AgentName != "" {
						<a href={ templ.SafeURL("/agents?agent=" + p.Run.AgentSlug) } class="font-semibold text-base-content hover:underline truncate max-w-[18rem]">{ p.Run.AgentName }</a>
					}
					<span class="text-base-content/30">·</span>
					<button
						type="button"
						class="bb-run-header__id"
						title="Copy run ID"
						@click="copyRunId()"
						:class="copiedRunId ? 'is-copied' : ''"
					>
						<span class="font-mono text-sm">{ p.Run.ShortID }</span>
						<i data-lucide="clipboard" class="w-3 h-3" x-show="!copiedRunId"></i>
						<i data-lucide="check" class="w-3 h-3" x-show="copiedRunId" x-cloak></i>
					</button>
					<span x-ref="status">
						@components.AgentRunStatusBadge(p.Run.Status)
					</span>
				</div>
				<div class="text-xs text-base-content/50 mt-0.5 flex items-center gap-1.5 flex-wrap">
					if p.Run.Trigger != "" {
						<span class="capitalize">{ p.Run.Trigger }</span>
						<span class="opacity-50">·</span>
					}
					<span title={ p.Run.StartedAt.Format(time.RFC3339) }>{ formatAgentRunStarted(p.Run.StartedAt) }</span>
					<span class="opacity-50">·</span>
					<span x-ref="duration" class="tabular-nums">{ formatAgentRunDuration(p.Run.DurationMs) }</span>
					<span x-show="status==='in_progress'" x-cloak class="inline-flex items-center gap-1 text-primary">
						<span class="loading loading-spinner loading-xs"></span>
						<span class="text-[0.65rem] uppercase tracking-wider">live</span>
					</span>
				</div>
			</div>
		</div>
		<div class="bb-run-header__actions">
			if TranscriptHasResultEvent(p.Transcript) {
				<button
					type="button"
					class="btn btn-sm btn-ghost gap-2"
					title="Jump to the run's final result bubble"
					@click="jumpToResult()"
				>
					<i data-lucide="flag-triangle-right" class="w-4 h-4"></i>
					Jump to result
				</button>
			}
			if p.Run.AgentSlug != "" {
				<a
					href={ templ.SafeURL("/agents?agent=" + p.Run.AgentSlug + "&run=1") }
					class="btn btn-sm btn-ghost gap-2"
					title="Run this agent again"
				>
					<i data-lucide="play" class="w-4 h-4"></i>
					Re-run
				</a>
			}
		</div>
	</div>
}

// agentRunHeaderBackHref returns the "back" target for the sticky header.
// Prefers the per-agent filter so consecutive runs of the same agent
// stay in scope; falls back to the global feed.
func agentRunHeaderBackHref(p AgentRunDetailProps) string {
	if p.Run.AgentSlug != "" {
		return "/agents?agent=" + p.Run.AgentSlug
	}
	return "/agents"
}

// agentRunErrorAlert renders the run's error_message in a soft warning/
// error alert above the metadata. When the message has a friendly
// translation (the typed RunError taxonomy in service/agent_orchestrator)
// the friendly text becomes the headline and the raw message is kept in
// a smaller secondary line for pasting into a bug report.
templ agentRunErrorAlert(run AgentRunRowProps) {
	if run.ErrorMessageFriendly != "" {
		<div class="alert alert-warning alert-soft mb-4">
			<i data-lucide="rotate-cw" class="w-4 h-4"></i>
			<div>
				<div class="font-medium">{ run.ErrorMessageFriendly }</div>
				<div class="text-xs opacity-70 mt-0.5 font-mono">{ run.ErrorMessage }</div>
			</div>
		</div>
	} else {
		<div class="alert alert-error alert-soft mb-4">
			<i data-lucide="triangle-alert" class="w-4 h-4"></i>
			<span class="whitespace-pre-wrap break-words">{ run.ErrorMessage }</span>
		</div>
	}
}

// agentRunDetailBreadcrumbs builds the breadcrumb trail. Agents › Agent
// name › <short ID>. The agent crumb links to /agents?agent=<slug> (the
// filtered feed) so consecutive runs stay in scope.
func agentRunDetailBreadcrumbs(p AgentRunDetailProps) []components.Breadcrumb {
	out := []components.Breadcrumb{{Label: "Agents", Href: "/agents"}}
	if p.Run.AgentSlug != "" {
		out = append(out, components.Breadcrumb{
			Label: runDetailAgentDisplay(p.Run),
			Href:  "/agents?agent=" + p.Run.AgentSlug,
		})
	}
	out = append(out, components.Breadcrumb{Label: p.Run.ShortID})
	return out
}

// ─── Transcript ─────────────────────────────────────────────────────

// agentRunTranscriptCard is the left-column chat thread. The inner
// `bb-run-thread` container is the x-ref="thread" target the Alpine
// poller refreshes from /-/agents/runs/{id}/live.
templ agentRunTranscriptCard(p AgentRunDetailProps) {
	<div class="bb-card p-4">
		<div class="flex items-center justify-between mb-3">
			<h2 class="text-sm font-semibold flex items-center gap-2">
				<i data-lucide="messages-square" class="w-4 h-4 text-base-content opacity-60"></i>
				Transcript
			</h2>
			<div class="flex items-center gap-2">
				<span x-ref="eventCount" class="text-xs text-base-content/40 tabular-nums">
					if len(p.Transcript) > 0 {
						{ strconv.Itoa(len(p.Transcript)) } events
					}
				</span>
				<button type="button" class="btn btn-ghost btn-xs gap-1.5" @click="toggleAll()" :title="allOpen ? 'Collapse all tool calls' : 'Expand all tool calls'">
					<i data-lucide="list-tree" class="w-3.5 h-3.5"></i>
					<span x-text="allOpen ? 'Collapse' : 'Expand'"></span>
				</button>
			</div>
		</div>
		if p.Truncated {
			<div class="alert alert-warning alert-soft mb-3 text-xs">
				<i data-lucide="alert-triangle" class="w-4 h-4"></i>
				<span>Showing first { strconv.Itoa(agentRunTranscriptMaxEventsConst) } events. Raw transcript on disk at <code class="font-mono text-[0.7rem]">{ p.TranscriptPath }</code>.</span>
			</div>
		}
		<div x-ref="thread" class="bb-run-thread">
			@AgentRunTranscriptFragment(p)
		</div>
	</div>
}

// agentRunTranscriptMaxEventsConst mirrors the admin handler cap. Defined
// here so the templ can show the same number in the truncation banner
// without importing the admin package (circular import).
const agentRunTranscriptMaxEventsConst = 500

// AgentRunTranscriptFragment renders just the inner transcript
// (per-event blocks + empty-state placeholder). Exported so the
// /-/agents/runs/{id}/live admin endpoint can render the fragment
// without re-rendering the surrounding card chrome.
templ AgentRunTranscriptFragment(p AgentRunDetailProps) {
	@agentRunPromptIntro(p)
	if len(p.Transcript) == 0 {
		<div class="bb-run-empty">
			<i data-lucide="hourglass" class="w-8 h-8 text-base-content/30"></i>
			if p.Run.Status == "in_progress" {
				<p class="text-sm text-base-content/60 mt-3">Transcript fills in as the agent works.</p>
			} else {
				<p class="text-sm text-base-content/60 mt-3">No transcript was captured for this run.</p>
			}
		</div>
	} else {
		<ul class="bb-chat-thread">
			for i, ev := range p.Transcript {
				@agentRunTranscriptEvent(ev, i)
			}
		</ul>
	}
}

// agentRunTranscriptEvent renders one transcript event. The shape branches
// per event kind:
//
//   - assistant_message → daisy chat-start with the agent avatar + the
//     model body rendered as Markdown (lists, code blocks, bold).
//   - user_message → daisy chat-end with the user/tool feedback as plain
//     text (no markdown — these are SDK-generated envelopes).
//   - tool_use → compact "tool call" row, click to expand the JSON input.
//   - tool_result → compact "tool result" row, click to expand the JSON
//     payload. We use components.JSONViewer for both so the pretty-print +
//     copy-to-clipboard affordance is consistent.
//   - result → "Run summary" pinned bubble with the cost/token grid.
//   - error → soft alert.
//   - raw → details with the original JSON for visibility into shapes the
//     classifier didn't recognise.
templ agentRunTranscriptEvent(ev TranscriptEvent, idx int) {
	switch ev.Type {
		case "assistant":
			<li class="chat chat-start">
				<div class="chat-image avatar avatar-placeholder">
					<div class="w-7 rounded-full bg-primary/15 text-primary">
						<i data-lucide="sparkles" class="w-3.5 h-3.5"></i>
					</div>
				</div>
				<div class="chat-header text-[0.65rem] uppercase tracking-wider text-base-content/50">
					Assistant
					if !ev.Timestamp.IsZero() {
						<time class="ml-1 normal-case tracking-normal text-base-content/40" datetime={ ev.Timestamp.Format(time.RFC3339) }>
							{ ev.Timestamp.Format("15:04:05") }
						</time>
					}
				</div>
				<div class="chat-bubble chat-bubble-primary">
					if ev.Text != "" {
						<div class="bb-prose" data-markdown={ ev.Text }></div>
					} else {
						<span class="text-xs opacity-60 italic">(no text content)</span>
					}
				</div>
			</li>
		case "user":
			<li class="chat chat-end">
				<div class="chat-image avatar avatar-placeholder">
					<div class="w-7 rounded-full bg-base-300 text-base-content/60">
						<i data-lucide="user" class="w-3.5 h-3.5"></i>
					</div>
				</div>
				<div class="chat-header text-[0.65rem] uppercase tracking-wider text-base-content/50">
					User
					if !ev.Timestamp.IsZero() {
						<time class="ml-1 normal-case tracking-normal text-base-content/40" datetime={ ev.Timestamp.Format(time.RFC3339) }>
							{ ev.Timestamp.Format("15:04:05") }
						</time>
					}
				</div>
				<div class="chat-bubble">
					if ev.Text != "" {
						<div class="bb-prose" data-markdown={ ev.Text }></div>
					} else {
						<span class="text-xs italic opacity-70">(tool results returned)</span>
					}
				</div>
			</li>
		case "tool_use":
			<li class="bb-tool-row">
				<details class="bb-tool" data-tool-event="use">
					<summary class="bb-tool__summary">
						<div class="bb-tool__icon"><i data-lucide="wrench" class="w-3.5 h-3.5"></i></div>
						<span class="bb-tool__label">
							if ev.ToolResultJSON != "" {
								Tool
							} else {
								Tool call · pending
							}
						</span>
						<span class="bb-tool__name font-mono">{ agentRunToolDisplay(ev.ToolName) }</span>
						if !ev.Timestamp.IsZero() {
							<time class="bb-tool__time" datetime={ ev.Timestamp.Format(time.RFC3339) }>{ ev.Timestamp.Format("15:04:05") }</time>
						}
						if !ev.ToolResultAt.IsZero() {
							<span class="bb-tool__time">→ { ev.ToolResultAt.Format("15:04:05") }</span>
						}
						<i data-lucide="chevron-right" class="bb-tool__chev w-3.5 h-3.5"></i>
					</summary>
					<div class="bb-tool__body bb-tool__body--paired">
						<div class="bb-tool__section">
							<div class="bb-tool__section-label"><i data-lucide="arrow-right" class="w-3 h-3"></i> Input</div>
							if ev.ToolInputJSON != "" {
								@components.JSONViewer(components.JSONViewerProps{Source: ev.ToolInputJSON, MaxDepth: 0, ShowCopy: true})
							} else {
								<span class="text-xs text-base-content/40 italic">(no input)</span>
							}
						</div>
						if ev.ToolResultJSON != "" {
							<div class="bb-tool__section">
								<div class="bb-tool__section-label bb-tool__section-label--result"><i data-lucide="arrow-left" class="w-3 h-3"></i> Result</div>
								@components.JSONViewer(components.JSONViewerProps{Source: ev.ToolResultJSON, MaxDepth: 0, ShowCopy: true})
							</div>
						}
					</div>
				</details>
			</li>
		case "tool_result":
			<li class="bb-tool-row">
				<details class="bb-tool" data-tool-event="result">
					<summary class="bb-tool__summary">
						<div class="bb-tool__icon bb-tool__icon--result"><i data-lucide="check-check" class="w-3.5 h-3.5"></i></div>
						<span class="bb-tool__label">Tool result</span>
						if ev.ToolName != "" {
							<span class="bb-tool__name font-mono">{ agentRunToolDisplay(ev.ToolName) }</span>
						}
						if !ev.Timestamp.IsZero() {
							<time class="bb-tool__time" datetime={ ev.Timestamp.Format(time.RFC3339) }>{ ev.Timestamp.Format("15:04:05") }</time>
						}
						<i data-lucide="chevron-right" class="bb-tool__chev w-3.5 h-3.5"></i>
					</summary>
					<div class="bb-tool__body">
						if ev.ToolResultJSON != "" {
							@components.JSONViewer(components.JSONViewerProps{Source: ev.ToolResultJSON, MaxDepth: 0, ShowCopy: true})
						} else {
							<span class="text-xs text-base-content/40 italic">(no result body)</span>
						}
					</div>
				</details>
			</li>
		case "system":
			<li class="bb-system-row">
				<i data-lucide="info" class="w-3.5 h-3.5 flex-shrink-0 mt-0.5 text-base-content/50"></i>
				<div class="min-w-0">
					<div class="text-[0.65rem] uppercase tracking-wider text-base-content/50">System</div>
					if ev.Text != "" {
						<div class="text-xs text-base-content/70 mt-0.5 whitespace-pre-wrap break-words">{ ev.Text }</div>
					}
					if !ev.Timestamp.IsZero() {
						<time class="text-[0.65rem] text-base-content/40 tabular-nums" datetime={ ev.Timestamp.Format(time.RFC3339) }>{ ev.Timestamp.Format("15:04:05") }</time>
					}
				</div>
			</li>
		case "result":
			<li class="bb-run-summary">
				<div class="bb-run-summary__head">
					<i data-lucide="flag-triangle-right" class="w-3.5 h-3.5"></i>
					<span class="text-[0.65rem] uppercase tracking-wider">Final result</span>
				</div>
				<div class="bb-run-summary__grid">
					<div>
						<div class="text-base-content/50 text-xs">Cost</div>
						<div>
							@agentRunCost(ev.CostUSD, "font-medium text-sm")
						</div>
					</div>
					<div>
						<div class="text-base-content/50 text-xs">Tokens in</div>
						<div class="text-sm font-medium tabular-nums">{ strconv.FormatInt(ev.TokensIn, 10) }</div>
					</div>
					<div>
						<div class="text-base-content/50 text-xs">Tokens out</div>
						<div class="text-sm font-medium tabular-nums">{ strconv.FormatInt(ev.TokensOut, 10) }</div>
					</div>
					<div>
						<div class="text-base-content/50 text-xs">Cache read</div>
						<div class="text-sm font-medium tabular-nums">{ strconv.FormatInt(ev.CacheRead, 10) }</div>
					</div>
					<div>
						<div class="text-base-content/50 text-xs">Cache write</div>
						<div class="text-sm font-medium tabular-nums">{ strconv.FormatInt(ev.CacheWrite, 10) }</div>
					</div>
				</div>
			</li>
		case "error":
			<li>
				<div class="alert alert-error alert-soft text-xs">
					<i data-lucide="alert-circle" class="w-4 h-4"></i>
					<div>
						<div class="font-medium">Error</div>
						<div class="text-base-content/70">{ ev.Text }</div>
					</div>
				</div>
			</li>
		default:
			<li class="bb-tool-row">
				<details class="bb-tool">
					<summary class="bb-tool__summary">
						<div class="bb-tool__icon bb-tool__icon--raw"><i data-lucide="code-2" class="w-3.5 h-3.5"></i></div>
						<span class="bb-tool__label">Raw event</span>
						if ev.Type != "" {
							<span class="bb-tool__name font-mono">{ ev.Type }</span>
						}
						<i data-lucide="chevron-right" class="bb-tool__chev w-3.5 h-3.5"></i>
					</summary>
					<div class="bb-tool__body">
						@components.JSONViewer(components.JSONViewerProps{Source: ev.RawJSON, MaxDepth: 1, ShowCopy: true})
					</div>
				</details>
			</li>
	}
}

// agentRunToolDisplay strips common MCP namespacing (`mcp__breadbox__`)
// from a tool name so the row reads cleanly. Falls back to the raw name
// when the prefix is something else.
func agentRunToolDisplay(name string) string {
	const mcpPrefix = "mcp__breadbox__"
	if len(name) > len(mcpPrefix) && name[:len(mcpPrefix)] == mcpPrefix {
		return name[len(mcpPrefix):]
	}
	return name
}

// ─── Side panel ─────────────────────────────────────────────────────

templ agentRunStatsCard(p AgentRunDetailProps) {
	<div class="bb-card p-4" x-ref="stats">
		<h3 class="text-xs font-semibold uppercase tracking-wider text-base-content/50 mb-3">Usage</h3>
		<dl class="space-y-2 text-sm">
			<div class="flex items-baseline justify-between gap-3">
				<dt class="text-base-content/60">Cost</dt>
				<dd>
					@agentRunCost(p.Run.CostUSD, "font-medium tabular-nums")
				</dd>
			</div>
			<div class="flex items-baseline justify-between gap-3">
				<dt class="text-base-content/60">Tokens (in / out)</dt>
				<dd class="font-medium tabular-nums">{ formatAgentRunTokens(p.Run.TokensIn, p.Run.TokensOut) }</dd>
			</div>
			<div class="flex items-baseline justify-between gap-3">
				<dt class="text-base-content/60">Turns</dt>
				<dd class="font-medium tabular-nums">{ strconv.Itoa(p.Run.Turns) }</dd>
			</div>
			<div class="flex items-baseline justify-between gap-3">
				<dt class="text-base-content/60">Duration</dt>
				<dd class="font-medium tabular-nums">{ formatAgentRunDuration(p.Run.DurationMs) }</dd>
			</div>
			<div class="flex items-baseline justify-between gap-3">
				<dt class="text-base-content/60">Finished</dt>
				<dd class="font-medium tabular-nums">{ formatAgentRunFinished(p.Run.FinishedAt) }</dd>
			</div>
			if p.Run.HitCap != "" {
				<div class="flex items-baseline justify-between gap-3">
					<dt class="text-base-content/60">Hit cap</dt>
					<dd><span class="badge badge-soft badge-warning badge-xs">{ p.Run.HitCap }</span></dd>
				</div>
			}
		</dl>
	</div>
}

// agentRunNoteCard renders the operator note as a click-to-edit block.
// Default mode shows the note (or "Add a note…" placeholder); clicking
// flips into a textarea that PATCHes /api/v1/agents/runs/{shortId} on
// save. No more full-page POST → reload.
templ agentRunNoteCard(p AgentRunDetailProps) {
	<div
		class="bb-card p-4"
		x-data="agentRunNote"
		data-short-id={ p.Run.ShortID }
		data-initial={ p.Run.Note }
	>
		<div class="flex items-center justify-between mb-2">
			<h3 class="text-xs font-semibold uppercase tracking-wider text-base-content/50 flex items-center gap-1.5">
				<i data-lucide="sticky-note" class="w-3 h-3"></i>
				Operator note
			</h3>
			<button
				type="button"
				class="btn btn-ghost btn-xs"
				x-show="!editing && !saving"
				@click="startEdit()"
			>
				<i data-lucide="pencil" class="w-3.5 h-3.5"></i>
			</button>
		</div>
		<div x-show="!editing" x-cloak>
			<p
				class="text-sm whitespace-pre-wrap text-base-content/80"
				x-text="value || ''"
				x-show="value"
			></p>
			<button
				type="button"
				class="text-sm text-base-content/40 italic hover:text-base-content/70 text-left w-full"
				x-show="!value"
				@click="startEdit()"
			>
				Add a note about this run…
			</button>
		</div>
		<form
			x-show="editing"
			x-cloak
			@submit.prevent="save()"
			class="space-y-2"
		>
			<textarea
				x-ref="textarea"
				x-model="draft"
				name="note"
				maxlength="2000"
				rows="3"
				placeholder="Why was this run interesting?"
				class="textarea textarea-sm w-full"
			></textarea>
			<div class="flex items-center justify-between gap-2">
				<span x-show="error" x-text="error" class="text-xs text-error"></span>
				<div class="flex items-center gap-1 ml-auto">
					<button type="button" class="btn btn-ghost btn-xs" @click="cancel()">Cancel</button>
					<button type="submit" class="btn btn-primary btn-xs" :disabled="saving">
						<span x-show="!saving">Save</span>
						<span x-show="saving" x-cloak><span class="loading loading-spinner loading-xs"></span></span>
					</button>
				</div>
			</div>
		</form>
	</div>
}

// agentRunToolsCard surfaces the per-tool call counts for the run.
// Helps the operator answer "which tools did this agent lean on?"
// without scrolling the transcript. Hidden entirely when the run made
// no tool calls (a pure-conversation agent).
templ agentRunToolsCard(p AgentRunDetailProps) {
	if usage := ComputeToolUsage(p.Transcript); len(usage) > 0 {
		<div class="bb-card p-4">
			<h3 class="text-xs font-semibold uppercase tracking-wider text-base-content/50 mb-2 flex items-center gap-1.5">
				<i data-lucide="wrench" class="w-3 h-3"></i>
				Tools used
			</h3>
			<ul class="space-y-1">
				for _, t := range usage {
					<li class="flex items-baseline justify-between gap-2 text-sm">
						<span class="font-mono text-xs text-base-content/80 truncate">{ t.Name }</span>
						<span class="badge badge-ghost badge-xs tabular-nums">{ strconv.Itoa(t.Count) }</span>
					</li>
				}
			</ul>
		</div>
	}
}

templ agentRunReportsCard(p AgentRunDetailProps) {
	<div class="bb-card p-4">
		<h3 class="text-xs font-semibold uppercase tracking-wider text-base-content/50 mb-2 flex items-center gap-1.5">
			<i data-lucide="file-text" class="w-3 h-3"></i>
			Reports
		</h3>
		<ul class="space-y-1.5">
			for _, rep := range p.Run.Reports {
				<li>
					<a
						href={ templ.SafeURL("/reports/" + rep.ShortID) }
						class="flex items-start gap-2 text-sm hover:bg-base-200/60 rounded-md px-2 py-1.5 -mx-2 no-underline"
					>
						<i data-lucide="file-text" class="w-3.5 h-3.5 mt-0.5 text-base-content/50 flex-shrink-0"></i>
						<span class="line-clamp-2 text-base-content/80">{ rep.Title }</span>
					</a>
				</li>
			}
		</ul>
	</div>
}

// agentRunPromptIntro renders the system/user/prefix prompts as the
// FIRST entries in the chat thread, before any model turn. Each is in
// its own collapsed-by-default <details> so the chrome stays out of
// the way until the operator wants to read them. Bodies render via
// the shared marked + DOMPurify pipeline (data-markdown) so they look
// the same as reports and chat bubbles.
templ agentRunPromptIntro(p AgentRunDetailProps) {
	if p.SystemPrompt != "" || p.Prompt != "" || p.PromptPrefix != "" {
		<div class="bb-prompt-intro">
			if p.SystemPrompt != "" {
				<details class="bb-prompt-collapse" data-prompt-kind="system">
					<summary>
						<i data-lucide="settings" class="w-3.5 h-3.5"></i>
						<span class="bb-prompt-collapse__label">System prompt</span>
						<i data-lucide="chevron-right" class="bb-prompt-collapse__chev w-3.5 h-3.5"></i>
					</summary>
					<div class="bb-prompt-collapse__body">
						<div class="bb-prose" data-markdown={ p.SystemPrompt }></div>
					</div>
				</details>
			}
			if p.Prompt != "" {
				<details class="bb-prompt-collapse" data-prompt-kind="user">
					<summary>
						<i data-lucide="message-square" class="w-3.5 h-3.5"></i>
						<span class="bb-prompt-collapse__label">User prompt</span>
						<i data-lucide="chevron-right" class="bb-prompt-collapse__chev w-3.5 h-3.5"></i>
					</summary>
					<div class="bb-prompt-collapse__body">
						<div class="bb-prose" data-markdown={ p.Prompt }></div>
					</div>
				</details>
			}
			if p.PromptPrefix != "" {
				<details class="bb-prompt-collapse" data-prompt-kind="prefix">
					<summary>
						<i data-lucide="pen-line" class="w-3.5 h-3.5"></i>
						<span class="bb-prompt-collapse__label">Per-run prefix</span>
						<i data-lucide="chevron-right" class="bb-prompt-collapse__chev w-3.5 h-3.5"></i>
					</summary>
					<div class="bb-prompt-collapse__body">
						<div class="bb-prose" data-markdown={ p.PromptPrefix }></div>
					</div>
				</details>
			}
		</div>
	}
}

templ agentRunTranscriptPathCard(p AgentRunDetailProps) {
	<div class="bb-card p-3">
		<div class="text-[0.65rem] uppercase tracking-wider text-base-content/50 mb-1 flex items-center gap-1.5">
			<i data-lucide="file" class="w-3 h-3"></i>
			Transcript file
		</div>
		<code class="font-mono text-[0.7rem] text-base-content/70 break-all">{ p.TranscriptPath }</code>
	</div>
}

// pollSeconds returns the JS-side polling cadence for the live updater.
// We bias to 3 s for in_progress runs (the meta-refresh was 5 s before;
// AJAX polling is cheap and snappier feels more alive). Zero for any
// terminal status — the factory skips polling entirely.
func pollSeconds(p AgentRunDetailProps) string {
	if p.Run.Status == "in_progress" {
		return "3"
	}
	return "0"
}
