package pages

import (
	"time"

	"breadbox/internal/templates/components"
)

// design_agent_run_chat.templ holds the three sandbox sections shipped
// with the agent-run-detail redesign. They live in their own file so
// the agent-runs sprint can move the canonical examples around without
// disturbing the older sections.
//
//   - SectionMarkdownProse — the .bb-prose body styled by components.Markdown.
//   - SectionJSONViewer    — components.JSONViewer with copy + collapse.
//   - SectionAgentRunChat  — the chat-thread variants the redesigned
//                            /agents/runs/{id} page composes.

// ─── Markdown prose ─────────────────────────────────────────────────
// The canonical proving ground for the single server-side markdown
// renderer (internal/markdown: goldmark + chroma + bluemonday). Every
// production surface — agent transcripts, reports, transaction comments,
// the workflow prompt preview — renders through @components.Markdown into
// the same .bb-prose, so what you see here is what those pages render.
templ SectionMarkdownProse() {
	<div class="flex flex-col gap-6">
		@designExample(
			"Assistant text",
			"components.Markdown renders a string of agent-emitted text — headings, lists, emphasis, blockquotes — inside a `.bb-prose` wrapper. The run-detail chat bubble and the agent-prompt panes are the primary consumers.",
		) {
			<div class="bb-card p-4">
				@components.Markdown(designMarkdownSampleAssistant())
			</div>
		}
		@designExample(
			"Headings & anchors",
			"All six ATX levels render; each heading gets an auto-generated `id` slug (goldmark WithAutoHeadingID) so long reports get linkable, scrollable sections.",
		) {
			<div class="bb-card p-4">
				@components.Markdown(designMarkdownSampleHeadings())
			</div>
		}
		@designExample(
			"Lists & task lists",
			"Ordered, unordered, and nested lists. GFM task-list checkboxes (`- [x]` / `- [ ]`) render as read-only checkboxes — common in agent plans and report checklists.",
		) {
			<div class="bb-card p-4">
				@components.Markdown(designMarkdownSampleLists())
			</div>
		}
		@designExample(
			"Syntax highlighting",
			"Fenced code blocks are highlighted server-side by chroma (class-based tokens themed via CSS, light + dark — no JS). Language is taken from the fence info string.",
		) {
			<div class="bb-card p-4">
				@components.Markdown(designMarkdownSampleCode())
			</div>
		}
		@designExample(
			"GFM tables",
			"GitHub-flavored tables with column alignment (`:--`, `:-:`, `--:`). Used for the cost/amount columns in agent post-mortem reports.",
		) {
			<div class="bb-card p-4">
				@components.Markdown(designMarkdownSampleTable())
			</div>
		}
		@designExample(
			"Callouts / admonitions",
			"GitHub-style > [!NOTE] / [!TIP] / [!IMPORTANT] / [!WARNING] / [!CAUTION] render as colored, icon'd boxes — ideal for agent reports flagging things. Pure server-side (goldmark blockquote transform + lucide icons).",
		) {
			<div class="bb-card p-4">
				@components.Markdown(designMarkdownSampleCallouts())
			</div>
		}
		@designExample(
			"Typography",
			"Inline `code`, **bold**, *italic*, ~~strikethrough~~, autolinked URLs, and the Typographer extension (smart quotes, en/em dashes, ellipsis).",
		) {
			<div class="bb-card p-4">
				@components.Markdown(designMarkdownSampleTypography())
			</div>
		}
		@designExample(
			"Hard-wraps (comments)",
			"@components.MarkdownBreaks turns a single newline into a line break — the chat-style variant transaction comments use, so a multi-line composer note keeps its shape.",
		) {
			<div class="bb-card p-4">
				@components.MarkdownBreaks(designMarkdownSampleBreaks())
			</div>
		}
		@designExample(
			"Report scale (bb-prose-lg)",
			"@components.MarkdownLarge adds the .bb-prose-lg modifier — larger headings and more generous spacing for full-page report bodies.",
		) {
			<div class="bb-card p-4">
				@components.MarkdownLarge(designMarkdownSampleHeadings())
			</div>
		}
		@designExample(
			"Safety (XSS-inert)",
			"Raw HTML in the source is dropped (goldmark WithUnsafe off) and the output is sanitized by bluemonday. `<script>`, event handlers, and `javascript:`/`data:` links never survive — only http/https/mailto links render.",
		) {
			<div class="bb-card p-4">
				@components.Markdown(designMarkdownSampleSafety())
			</div>
		}
	</div>
}

// designMarkdownSampleAssistant returns a representative chunk of
// agent-emitted text. Lives as a Go helper because templ's lexer fights
// with multi-line string literals that contain backticks.
func designMarkdownSampleAssistant() string {
	return "## What I'm doing\n\n" +
		"I'm going to look at your **last 30 days of transactions** and pick out the merchants that are new since your last review. Here's the plan:\n\n" +
		"1. Pull every transaction from `2026-04-25` onward.\n" +
		"2. Bucket by `merchant_name` (case-insensitive).\n" +
		"3. Filter to merchants that don't appear in your prior 90 days.\n" +
		"4. Surface the top 5 by total amount.\n\n" +
		"You can intervene at any step with a quick note like *\"skip restaurants\"* and I'll re-scope.\n\n" +
		"> Heads-up: I'll mark anything ambiguous for review rather than guessing."
}

func designMarkdownSampleHeadings() string {
	return "# Monthly spend review\n\n" +
		"## Summary\n\n" +
		"Spending was up 8% month-over-month, driven by groceries.\n\n" +
		"### Groceries\n\n" +
		"Whole Foods accounted for most of the increase.\n\n" +
		"#### Notable merchants\n\n" +
		"A few new merchants showed up this month."
}

func designMarkdownSampleLists() string {
	return "Plan for this run:\n\n" +
		"- [x] Pull the last 30 days of transactions\n" +
		"- [x] Bucket by merchant\n" +
		"- [ ] Surface the top 5 by total\n" +
		"- [ ] Flag anything ambiguous for review\n\n" +
		"Ordered steps with nesting:\n\n" +
		"1. Group transactions\n" +
		"   - case-insensitive merchant match\n" +
		"   - ignore pending\n" +
		"2. Rank by total amount\n" +
		"3. Return the top 5"
}

func designMarkdownSampleCode() string {
	return "A SQL query:\n\n" +
		"```sql\nSELECT merchant_name, SUM(amount) AS total\nFROM transactions\nWHERE date >= NOW() - INTERVAL '30 days'\nGROUP BY merchant_name\nORDER BY total DESC\nLIMIT 5;\n```\n\n" +
		"The Go that runs it:\n\n" +
		"```go\nfunc topMerchants(ctx context.Context, db *pgxpool.Pool) ([]Merchant, error) {\n\trows, err := db.Query(ctx, topMerchantsSQL)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"query: %w\", err)\n\t}\n\tdefer rows.Close()\n\treturn scanMerchants(rows)\n}\n```\n\n" +
		"And a shell one-liner:\n\n" +
		"```bash\ncurl -s \"$BB/api/v1/transactions?limit=5\" | jq '.transactions[].merchant_name'\n```"
}

func designMarkdownSampleTable() string {
	return "Top 5 merchants from the dry run:\n\n" +
		"| Merchant      | Txns | Total       |\n" +
		"|:--------------|-----:|------------:|\n" +
		"| Whole Foods   |   12 |   $384.12   |\n" +
		"| Lyft          |   18 |   $192.40   |\n" +
		"| Apple.com     |    3 |    $59.97   |"
}

func designMarkdownSampleCallouts() string {
	return "> [!NOTE]\n> Pulled 47 transactions from the last 30 days.\n\n" +
		"> [!TIP]\n> Create a rule for Whole Foods to auto-categorize future charges.\n\n" +
		"> [!IMPORTANT]\n> Two accounts share the merchant \"Apple\" — totals are combined.\n\n" +
		"> [!WARNING]\n> A charge posted twice on the same day. Flagged for review.\n\n" +
		"> [!CAUTION]\n> This rule would re-categorize 312 historical transactions."
}

func designMarkdownSampleTypography() string {
	return "Inline `code`, **bold**, *italic*, and ~~struck-through~~ text all render. " +
		"Bare URLs autolink: https://breadbox.sh.\n\n" +
		"The Typographer extension cleans up punctuation — \"smart quotes\", an en-dash (1–5), " +
		"an em-dash (really -- it does), and an ellipsis..."
}

func designMarkdownSampleBreaks() string {
	return "Heads up on this charge:\n" +
		"it posted twice on the same day.\n" +
		"Marking the duplicate for review."
}

func designMarkdownSampleSafety() string {
	return "Links: a good [example.com](https://example.com) survives; a [bad one](javascript:alert(1)) is stripped to plain text.\n\n" +
		"Raw HTML is dropped entirely — an inline <script>alert('hi')</script> and an " +
		"<img src=x onerror=alert(1)> never reach the page.\n\n" +
		"Even a crafted [data-URI link](data:text/html,<script>alert(1)</script>) is neutralized."
}

// ─── JSON viewer ────────────────────────────────────────────────────
templ SectionJSONViewer() {
	<div class="flex flex-col gap-6">
		@designExample(
			"Default",
			"Server-rendered, zero-dep. Objects + arrays collapse on click; every level is its own <details> so deep payloads stay manageable.",
		) {
			<div class="bb-card p-4 max-w-2xl">
				@components.JSONViewer(components.JSONViewerProps{
					Source: designJSONSample(),
				})
			</div>
		}
		@designExample(
			"With copy button",
			"ShowCopy adds a clipboard affordance in the top-right corner. The copy payload is the original source string — preserving any non-pretty-print formatting your caller passed in.",
		) {
			<div class="bb-card p-4 max-w-2xl">
				@components.JSONViewer(components.JSONViewerProps{
					Source:   designJSONSample(),
					ShowCopy: true,
				})
			</div>
		}
		@designExample(
			"Collapsed-by-default",
			"MaxDepth=1 starts everything below the top-level keys collapsed. Useful for long tool-result payloads where the operator just wants to see the keys before diving in.",
		) {
			<div class="bb-card p-4 max-w-2xl">
				@components.JSONViewer(components.JSONViewerProps{
					Source:   designJSONLargeSample(),
					MaxDepth: 1,
					ShowCopy: true,
				})
			</div>
		}
		@designExample(
			"Empty + malformed",
			"Empty source renders an em-dash placeholder. Unparseable JSON falls back to a plain `<pre>` so the operator sees the raw payload — never an error.",
		) {
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
				<div class="bb-card p-4">
					<div class="text-[0.65rem] uppercase tracking-wider text-base-content/50 mb-2">Empty</div>
					@components.JSONViewer(components.JSONViewerProps{Source: ""})
				</div>
				<div class="bb-card p-4">
					<div class="text-[0.65rem] uppercase tracking-wider text-base-content/50 mb-2">Malformed</div>
					@components.JSONViewer(components.JSONViewerProps{Source: `{ "broken": true,`})
				</div>
			</div>
		}
	</div>
}

func designJSONSample() string {
	return `{
  "merchant": "Whole Foods Market",
  "category": "groceries",
  "items": ["produce", "deli", "snacks"],
  "amount": 42.18,
  "tax": 2.13,
  "approved": true,
  "notes": null
}`
}

func designJSONLargeSample() string {
	return `{
  "run_id": "run_dGHbZfr6",
  "tools_used": [
    {"name": "query_transactions", "input": {"start": "2026-04-25", "limit": 100}, "result_size": 87},
    {"name": "list_merchants", "input": {"order": "total_desc"}, "result_size": 14},
    {"name": "create_review", "input": {"transaction_id": "tx_abc123", "reason": "uncategorized"}}
  ],
  "summary": {
    "messages": 12,
    "tool_calls": 3,
    "duration_ms": 18420,
    "cost_usd": 0.0427
  },
  "metadata": {
    "model": "claude-sonnet-4-6",
    "temperature": null
  }
}`
}

// ─── Agent run chat thread ──────────────────────────────────────────
templ SectionAgentRunChat() {
	<div class="flex flex-col gap-6">
		@designExample(
			"Assistant + user bubbles",
			"Daisy `chat chat-start` for the agent (left-aligned, primary-tinted avatar); `chat chat-end` for the user / tool envelopes. Assistant text routes through components.Markdown so lists, code, and bold render exactly as the agent intended.",
		) {
			<div class="bb-card p-4 max-w-2xl">
				<ul class="bb-chat-thread">
					@agentRunTranscriptEvent(designChatAssistantEvent(), 0)
					@agentRunTranscriptEvent(designChatUserEvent(), 1)
				</ul>
			</div>
		}
		@designExample(
			"Tool call + result rows",
			"Tool events render as compact rows that expand into the JSONViewer. We strip the `mcp__breadbox__` prefix from tool names so the row stays readable. Tool results inherit the name of the tool_use they're answering (via tool_use_id) so the operator can pair them at a glance. Color tone: blue tile for `tool_use`, green for `tool_result`.",
		) {
			<div class="bb-card p-4 max-w-2xl">
				<ul class="bb-chat-thread">
					@agentRunTranscriptEvent(designChatToolUseEvent(), 0)
					@agentRunTranscriptEvent(designChatToolResultEvent(), 1)
				</ul>
			</div>
		}
		@designExample(
			"System events",
			"SDK init messages, cost_cap_hit, and other non-conversational events render as a subtle row beneath the chat thread. Dashed border + neutral icon to keep them out of the way.",
		) {
			<div class="bb-card p-4 max-w-2xl">
				<ul class="bb-chat-thread">
					@agentRunTranscriptEvent(designChatSystemEvent(), 0)
				</ul>
			</div>
		}
		@designExample(
			"Final result + error",
			"`result` events render as a pinned stats bubble at the bottom of the thread. `error` events use a soft alert so they don't dominate the thread.",
		) {
			<div class="bb-card p-4 max-w-2xl">
				<ul class="bb-chat-thread">
					@agentRunTranscriptEvent(designChatResultEvent(), 0)
					@agentRunTranscriptEvent(designChatErrorEvent(), 1)
				</ul>
			</div>
		}
	</div>
}

// designChatAssistantEvent returns a representative assistant message
// for the sandbox. We share a single helper across the three example
// blocks so the sample stays consistent and only changes in one place.
func designChatAssistantEvent() TranscriptEvent {
	return TranscriptEvent{
		Type:      "assistant",
		Role:      "assistant",
		Text:      designMarkdownSampleAssistant(),
		Timestamp: time.Now().Add(-3 * time.Minute),
	}
}

func designChatUserEvent() TranscriptEvent {
	return TranscriptEvent{
		Type:      "user",
		Role:      "user",
		Text:      "Skip restaurants. Focus on the grocery + subscription buckets.",
		Timestamp: time.Now().Add(-2*time.Minute - 30*time.Second),
	}
}

func designChatToolUseEvent() TranscriptEvent {
	return TranscriptEvent{
		Type:          "tool_use",
		ToolName:      "mcp__breadbox__query_transactions",
		ToolUseID:     "toolu_demo_01",
		ToolInputJSON: `{"start": "2026-04-25", "limit": 100, "categories": ["groceries", "subscriptions"]}`,
		Timestamp:     time.Now().Add(-2 * time.Minute),
	}
}

func designChatToolResultEvent() TranscriptEvent {
	return TranscriptEvent{
		Type:           "tool_result",
		ToolName:       "mcp__breadbox__query_transactions",
		ToolUseID:      "toolu_demo_01",
		ToolResultJSON: `{"count": 47, "sample": [{"merchant": "Whole Foods", "amount": 42.18}, {"merchant": "Spotify", "amount": 9.99}], "has_more": true}`,
		Timestamp:      time.Now().Add(-1*time.Minute - 50*time.Second),
	}
}

func designChatSystemEvent() TranscriptEvent {
	return TranscriptEvent{
		Type:      "system",
		Text:      "Cost cap reached: stopping after 5 turns. Remaining budget: $0.00.",
		Timestamp: time.Now().Add(-30 * time.Second),
	}
}

func designChatResultEvent() TranscriptEvent {
	return TranscriptEvent{
		Type:       "result",
		CostUSD:    0.0427,
		TokensIn:   18213,
		TokensOut:  842,
		CacheRead:  4096,
		CacheWrite: 1284,
		Timestamp:  time.Now().Add(-1 * time.Minute),
	}
}

func designChatErrorEvent() TranscriptEvent {
	return TranscriptEvent{
		Type:      "error",
		Text:      "anthropic.api_error: 529 — server overloaded, retrying",
		Timestamp: time.Now().Add(-45 * time.Second),
	}
}
