package pages

import (
	"fmt"

	"breadbox/internal/templates/components"
)

// Access renders the combined API Keys + OAuth Clients tab. Each is a
// borderless SettingsSection (.claude/rules/settings.md). Creating a key
// or client is a one-click action that mints with sensible defaults and
// reveals the plaintext inline — an optional "Custom…" path lets the user
// set a name + scope first. No subpages.
templ Access(p AccessProps) {
	<div>
		@settingsTabHeader(settingsTabHeaderProps{
			Title:    "API Keys",
			Subtitle: "Keys and OAuth clients for programmatic and external access",
		})
		@accessAPIKeysSection(p)
		@accessOAuthClientsSection(p)
	</div>
}

// ---------------------------------------------------------------------
// API Keys
// ---------------------------------------------------------------------

templ accessAPIKeysSection(p AccessProps) {
	<div id="api-keys">
		@components.SettingsSection(components.SettingsSectionProps{
			Icon:    "key",
			Title:   "API keys",
			Caption: accessKeysCaption(p),
			Bare:    true,
		}) {
			@accessCreateBar(accessCreateBarProps{
				Action:     "/settings/api-keys/new",
				CSRFToken:  p.CSRFToken,
				CreateText: "Create key",
				NameHint:   "e.g. Claude MCP, Dashboard",
				ScopeNote:  "Read-only keys can query data but can't trigger syncs, categorize, or use write MCP tools.",
			})
			if p.JustCreatedKey != nil {
				@accessReveal(p.JustCreatedKey, "API key")
			}
			@components.SettingsCard(components.SettingsCardProps{}) {
				if len(p.ActiveKeys) == 0 && len(p.RevokedKeys) == 0 && p.JustCreatedKey == nil {
					@accessEmptyRow("Create one to connect MCP agents or integrate with external tools.")
				} else {
					for _, k := range p.ActiveKeys {
						@accessActiveKeyRow(k, p.IsAdmin, p.CSRFToken)
					}
				}
			}
			if len(p.RevokedKeys) > 0 {
				@accessRevokedDisclosure(len(p.RevokedKeys)) {
					for _, k := range p.RevokedKeys {
						@accessRevokedKeyRow(k)
					}
				}
			}
		}
	</div>
}

func accessKeysCaption(p AccessProps) string {
	if !p.HasAnyKeys && p.JustCreatedKey == nil {
		return "Direct REST API and MCP access via the X-API-Key header."
	}
	out := fmt.Sprintf("%d active", len(p.ActiveKeys))
	if len(p.RevokedKeys) > 0 {
		out += fmt.Sprintf(" · %d revoked", len(p.RevokedKeys))
	}
	return out
}

templ accessActiveKeyRow(k AccessKeyRow, isAdmin bool, csrfToken string) {
	<div class="bb-settings-row" x-data="{ confirming: false }">
		<div class="bb-settings-row__main">
			<div class="bb-settings-row__label">
				<span class="truncate">{ k.Name }</span>
				@accessScopeBadge(k.Scope)
			</div>
			<div class="bb-settings-row__caption flex items-center gap-x-2 gap-y-0.5 flex-wrap">
				<code class="font-mono text-[0.65rem] text-base-content/45">{ k.KeyPrefix }…</code>
				<span class="text-base-content/40">Created { k.CreatedAtShort }</span>
				if k.LastUsedRelative != "" {
					<span class="text-base-content/40">Last used { k.LastUsedRelative }</span>
				}
			</div>
		</div>
		if isAdmin {
			<div class="bb-settings-row__control">
				@accessRevokeControl(accessAPIKeyRevokeURL(k.ID), csrfToken, "API key "+k.Name)
			</div>
		}
	</div>
}

templ accessRevokedKeyRow(k AccessKeyRow) {
	<div class="bb-settings-row">
		<div class="bb-settings-row__main">
			<div class="bb-settings-row__label">
				<span class="text-base-content/40 line-through truncate">{ k.Name }</span>
				<span class="badge badge-soft badge-error badge-xs shrink-0">Revoked</span>
			</div>
			<div class="bb-settings-row__caption flex items-center gap-2 flex-wrap">
				<code class="font-mono text-[0.65rem] text-base-content/30">{ k.KeyPrefix }…</code>
				<span class="text-base-content/30">Created { k.CreatedAtShort }</span>
			</div>
		</div>
	</div>
}

// ---------------------------------------------------------------------
// OAuth Clients
// ---------------------------------------------------------------------

templ accessOAuthClientsSection(p AccessProps) {
	<div id="oauth-clients">
		@components.SettingsSection(components.SettingsSectionProps{
			Icon:    "fingerprint",
			Title:   "OAuth clients",
			Caption: accessClientsCaption(p),
			Bare:    true,
		}) {
			@accessCreateBar(accessCreateBarProps{
				Action:     "/settings/oauth-clients/new",
				CSRFToken:  p.CSRFToken,
				CreateText: "Create client",
				NameHint:   "e.g. Claude Desktop",
				ScopeNote:  "Scope applies to every connection authorized through this client.",
			})
			if p.JustCreatedClient != nil {
				@accessReveal(p.JustCreatedClient, "OAuth client")
			}
			@components.SettingsCard(components.SettingsCardProps{}) {
				if len(p.ActiveClients) == 0 && len(p.RevokedClients) == 0 && p.JustCreatedClient == nil {
					@accessEmptyRow("Create one to connect external AI services to your MCP server.")
				} else {
					for _, c := range p.ActiveClients {
						@accessActiveClientRow(c, p.IsAdmin, p.CSRFToken)
					}
				}
			}
			if len(p.RevokedClients) > 0 {
				@accessRevokedDisclosure(len(p.RevokedClients)) {
					for _, c := range p.RevokedClients {
						@accessRevokedClientRow(c)
					}
				}
			}
		}
	</div>
}

func accessClientsCaption(p AccessProps) string {
	if !p.HasAnyClients && p.JustCreatedClient == nil {
		return "External connector access (e.g. Claude) via OAuth."
	}
	out := fmt.Sprintf("%d active", len(p.ActiveClients))
	if len(p.RevokedClients) > 0 {
		out += fmt.Sprintf(" · %d revoked", len(p.RevokedClients))
	}
	return out
}

templ accessActiveClientRow(c AccessClientRow, isAdmin bool, csrfToken string) {
	<div class="bb-settings-row" x-data="{ confirming: false }">
		<div class="bb-settings-row__main">
			<div class="bb-settings-row__label">
				<span class="truncate">{ c.Name }</span>
				@accessScopeBadge(c.Scope)
			</div>
			<div class="bb-settings-row__caption flex items-center gap-2 flex-wrap">
				<code class="font-mono text-[0.65rem] text-base-content/45">{ c.ClientIDPrefix }…</code>
				<span class="text-base-content/40">Created { c.CreatedAtShort }</span>
			</div>
		</div>
		if isAdmin {
			<div class="bb-settings-row__control">
				@accessRevokeControl(accessOAuthClientRevokeURL(c.ID), csrfToken, "OAuth client "+c.Name)
			</div>
		}
	</div>
}

templ accessRevokedClientRow(c AccessClientRow) {
	<div class="bb-settings-row">
		<div class="bb-settings-row__main">
			<div class="bb-settings-row__label">
				<span class="text-base-content/40 line-through truncate">{ c.Name }</span>
				<span class="badge badge-soft badge-error badge-xs shrink-0">Revoked</span>
			</div>
			<div class="bb-settings-row__caption flex items-center gap-2 flex-wrap">
				<code class="font-mono text-[0.65rem] text-base-content/30">{ c.ClientIDPrefix }…</code>
				<span class="text-base-content/30">Created { c.CreatedAtShort }</span>
			</div>
		</div>
	</div>
}

// ---------------------------------------------------------------------
// Shared pieces — create bar, reveal, scope badge, revoke, disclosure
// ---------------------------------------------------------------------

type accessCreateBarProps struct {
	Action     string // POST endpoint that mints + flashes the secret
	CSRFToken  string
	CreateText string // "Create key" / "Create client"
	NameHint   string // placeholder for the custom-name input
	ScopeNote  string // one-line note under the scope select
}

// accessCreateBar is the one-click create affordance: a primary button
// that mints immediately with defaults (full access, auto name), plus a
// "Custom…" toggle that reveals an inline name + scope form. Both submit
// to the same endpoint; the in-page swapper intercepts the POST so the
// reveal lands inline without a navigation.
templ accessCreateBar(p accessCreateBarProps) {
	<div class="flex flex-col gap-3 mb-5" x-data="{ custom: false }">
		<div class="flex justify-end items-center gap-2" x-show="!custom">
			<button type="button" class="btn btn-ghost btn-sm gap-1.5" @click="custom = true">
				@components.LucideIcon("sliders-horizontal", "w-3.5 h-3.5")
				Custom…
			</button>
			<form method="POST" action={ templ.SafeURL(p.Action) }>
				<input type="hidden" name="_csrf" value={ p.CSRFToken }/>
				<input type="hidden" name="scope" value="full_access"/>
				<button type="submit" class="btn btn-primary btn-sm btn-soft gap-2">
					@components.LucideIcon("plus", "w-4 h-4")
					{ p.CreateText }
				</button>
			</form>
		</div>
		<form
			method="POST"
			action={ templ.SafeURL(p.Action) }
			x-show="custom"
			x-cloak
			class="rounded-xl border border-base-200 bg-base-200/30 p-4 flex flex-col gap-3"
		>
			<input type="hidden" name="_csrf" value={ p.CSRFToken }/>
			<div class="flex flex-col sm:flex-row gap-3">
				<label class="flex-1 flex flex-col gap-1.5">
					<span class="text-xs font-medium text-base-content/60">Name</span>
					<input type="text" name="name" class="input input-sm w-full" placeholder={ p.NameHint }/>
				</label>
				<label class="flex flex-col gap-1.5">
					<span class="text-xs font-medium text-base-content/60">Scope</span>
					<select name="scope" class="select select-sm bg-base-200">
						<option value="full_access">Full access</option>
						<option value="read_only">Read only</option>
					</select>
				</label>
			</div>
			<p class="text-xs text-base-content/45 leading-snug">{ p.ScopeNote }</p>
			<div class="flex items-center justify-end gap-2">
				<button type="button" class="btn btn-ghost btn-sm" @click="custom = false">Cancel</button>
				<button type="submit" class="btn btn-primary btn-sm gap-2">
					@components.LucideIcon("plus", "w-4 h-4")
					{ p.CreateText }
				</button>
			</div>
		</form>
	</div>
}

// accessReveal renders the one-time plaintext block shown right after a
// mint. The whole point is "copy it now" — so it's prominent (success
// tint), copyable in one tap, and gone on the next render.
templ accessReveal(rv *AccessReveal, kind string) {
	<div class="rounded-xl border border-success/30 bg-success/[0.06] p-4 mb-5">
		<div class="flex items-center gap-2 text-sm font-medium text-success mb-1">
			@components.LucideIcon("circle-check", "w-4 h-4 shrink-0")
			<span>{ kind } created</span>
			@accessScopeBadge(rv.Scope)
		</div>
		<p class="text-xs text-base-content/55 mb-3">
			Copy { accessSecretLabel(kind) } now — for security it won't be shown again.
		</p>
		if rv.ClientID != "" {
			@accessCopyField("Client ID", rv.ClientID, false)
		}
		@accessCopyField(accessSecretFieldLabel(kind), rv.Secret, true)
	</div>
}

// accessCopyField is one labeled, copyable value inside the reveal block.
templ accessCopyField(label, value string, primary bool) {
	<div class="mb-2 last:mb-0" x-data="{ copied: false }">
		<label class="text-[0.7rem] font-medium text-base-content/50 mb-1 block">{ label }</label>
		<div class="flex gap-2">
			<input
				type="text"
				value={ value }
				readonly
				x-ref="val"
				class="input input-sm font-mono flex-1 min-w-0 bg-base-100 text-xs"
			/>
			<button
				type="button"
				class={ accessCopyBtnClass(primary) }
				:class="copied && '!btn-success'"
				@click="navigator.clipboard.writeText($refs.val.value).then(() => { copied = true; setTimeout(() => copied = false, 2000) })"
			>
				<i data-lucide="clipboard" class="w-4 h-4" x-show="!copied"></i>
				<i data-lucide="check" class="w-4 h-4" x-show="copied" x-cloak></i>
				<span x-text="copied ? 'Copied' : 'Copy'"></span>
			</button>
		</div>
	</div>
}

func accessCopyBtnClass(primary bool) string {
	if primary {
		return "btn btn-sm btn-primary gap-1.5 shrink-0"
	}
	return "btn btn-sm btn-soft gap-1.5 shrink-0"
}

func accessSecretLabel(kind string) string {
	if kind == "OAuth client" {
		return "the client secret"
	}
	return "the key"
}

func accessSecretFieldLabel(kind string) string {
	if kind == "OAuth client" {
		return "Client secret"
	}
	return "API key"
}

// accessScopeBadge renders the inline scope chip used on rows + reveals.
templ accessScopeBadge(scope string) {
	if scope == "read_only" {
		<span class="badge badge-soft badge-warning badge-xs shrink-0">Read only</span>
	} else {
		<span class="badge badge-soft badge-primary badge-xs shrink-0">Full access</span>
	}
}

// accessRevokeControl is the inline two-step revoke affordance shared by
// key + client rows.
templ accessRevokeControl(action, csrfToken, ariaLabel string) {
	<div x-data="{ confirming: false }" class="contents">
		<div x-show="!confirming" class="contents">
			@components.OverflowMenu(components.OverflowMenuProps{
				AriaLabel: "Actions for " + ariaLabel,
				Size:      "xs",
				Items: []components.OverflowMenuItem{
					{
						Label:       "Revoke…",
						Icon:        "trash-2",
						OnClick:     "confirming = true; document.activeElement.blur()",
						Destructive: true,
					},
				},
			})
		</div>
		<form method="POST" action={ templ.SafeURL(action) } x-show="confirming" x-cloak>
			<input type="hidden" name="_csrf" value={ csrfToken }/>
			<span class="flex items-center gap-1.5 justify-end">
				<button type="submit" class="btn btn-error btn-xs btn-soft">Confirm</button>
				<button type="button" class="btn btn-ghost btn-xs" @click="confirming = false">Cancel</button>
			</span>
		</form>
	</div>
}

// accessRevokedDisclosure wraps the revoked rows behind a quiet toggle so
// they don't clutter the active list.
templ accessRevokedDisclosure(count int) {
	<div class="pt-2" x-data="{ open: false }">
		<button type="button" class="btn btn-ghost btn-xs text-base-content/40 gap-1.5" @click="open = !open">
			<i data-lucide="chevron-right" class="w-3 h-3 transition-transform" :class="open && 'rotate-90'"></i>
			{ fmt.Sprintf("%d revoked", count) }
		</button>
		<div x-show="open" x-cloak x-collapse class="opacity-60">
			{ children... }
		</div>
	</div>
}

// accessEmptyRow renders a quiet hint inside a section body when no rows
// exist yet — the header already names the section + carries the create
// affordance, so one short line is enough (no nested empty-state card).
templ accessEmptyRow(hint string) {
	<div class="bb-settings-row">
		<div class="bb-settings-row__main">
			<p class="text-sm text-base-content/50">{ hint }</p>
		</div>
	</div>
}
