package pages

import (
	"fmt"
	"strconv"
	"time"

	"breadbox/internal/templates/components"
)

// AgentRunsList renders the v1 admin run-history page. Two modes share the
// same component:
//   - "global": cross-agent view at /agents/runs.
//   - "agent":  per-agent view at /agents/{slug}/runs.
//
// The handler in internal/admin/agent_runs_page.go decides which based on
// the URL and fills AgentSlug/AgentName/AgentOptions accordingly.
templ AgentRunsList(p AgentRunsListProps) {
	@agentRunsHeader(p)
	@agentRunsFilterBar(p)
	if len(p.Rows) > 0 {
		@agentRunsTable(p)
		@agentRunsPagination(p)
	} else {
		@agentRunsEmpty(p)
	}
}

templ agentRunsHeader(p AgentRunsListProps) {
	<div class="bb-page-header">
		<div>
			if p.Mode == "agent" {
				<div class="text-xs text-base-content/50 mb-1">
					<a href="/agents" class="hover:underline">Agents</a>
					<span class="mx-1">/</span>
					<span>{ p.AgentName }</span>
					<span class="mx-1">/</span>
					<span>Runs</span>
				</div>
				<h1 class="bb-page-title">Runs &mdash; { p.AgentName }</h1>
				<p class="text-sm text-base-content/50 mt-1">
					History of every run, manual or scheduled, for this agent.
				</p>
			} else {
				<h1 class="bb-page-title">Run history</h1>
				<p class="text-sm text-base-content/50 mt-1">
					All agent runs across the household.
				</p>
			}
		</div>
		<div class="flex items-center gap-2">
			<a href="/agents" class="btn btn-ghost btn-sm rounded-xl">
				<i data-lucide="arrow-left" class="w-3.5 h-3.5"></i>
				Back to agents
			</a>
		</div>
	</div>
}

templ agentRunsFilterBar(p AgentRunsListProps) {
	<div class="bb-card mb-6 p-4">
		<form method="GET" action={ templ.SafeURL(agentRunsFormAction(p)) } class="bb-filter-form">
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-6 gap-3 mb-3">
				if p.Mode == "global" {
					<label class="bb-filter-label">
						Agent
						<select name="agent" class="select select-sm select-bordered w-full">
							<option value="">All agents</option>
							for _, opt := range p.AgentOptions {
								@agentRunsSelectOption(opt.Slug, opt.Name, p.Filters.AgentSlug)
							}
						</select>
					</label>
				}
				<label class="bb-filter-label">
					Status
					<select name="status" class="select select-sm select-bordered w-full">
						<option value="">All statuses</option>
						@agentRunsSelectOption("success", "Success", p.Filters.Status)
						@agentRunsSelectOption("error", "Error", p.Filters.Status)
						@agentRunsSelectOption("in_progress", "In progress", p.Filters.Status)
						@agentRunsSelectOption("skipped", "Skipped", p.Filters.Status)
						@agentRunsSelectOption("timeout", "Timeout", p.Filters.Status)
					</select>
				</label>
				<label class="bb-filter-label">
					Trigger
					<select name="trigger" class="select select-sm select-bordered w-full">
						<option value="">All triggers</option>
						@agentRunsSelectOption("cron", "Cron", p.Filters.Trigger)
						@agentRunsSelectOption("manual", "Manual", p.Filters.Trigger)
						@agentRunsSelectOption("webhook", "Webhook", p.Filters.Trigger)
					</select>
				</label>
				<label class="bb-filter-label">
					Hit cap
					<select name="hit_cap" class="select select-sm select-bordered w-full">
						<option value="">All</option>
						@agentRunsSelectOption("any", "Any cap", p.Filters.HitCap)
						@agentRunsSelectOption("max_turns", "Max turns", p.Filters.HitCap)
						@agentRunsSelectOption("max_budget", "Max budget", p.Filters.HitCap)
					</select>
				</label>
				<label class="bb-filter-label">
					Start
					<input type="date" name="start" value={ p.Filters.Start } class="input input-sm input-bordered w-full"/>
				</label>
				<label class="bb-filter-label">
					End
					<input type="date" name="end" value={ p.Filters.End } class="input input-sm input-bordered w-full"/>
				</label>
			</div>
			<div class="bb-filter-actions flex items-center gap-2">
				<button type="submit" class="btn btn-sm btn-primary rounded-xl">
					<i data-lucide="filter" class="w-3.5 h-3.5"></i>
					Apply
				</button>
				<a href={ templ.SafeURL(agentRunsFormAction(p)) } class="btn btn-sm btn-ghost rounded-xl">Clear</a>
			</div>
		</form>
	</div>
}

templ agentRunsSelectOption(value, label, current string) {
	if value == current {
		<option value={ value } selected>{ label }</option>
	} else {
		<option value={ value }>{ label }</option>
	}
}

templ agentRunsTable(p AgentRunsListProps) {
	<div class="bb-card overflow-x-auto">
		<table class="table table-sm">
			<thead>
				<tr>
					<th>Run</th>
					if p.Mode == "global" {
						<th>Agent</th>
					}
					<th>Status</th>
					<th>Trigger</th>
					<th>Started</th>
					<th class="text-right">Duration</th>
					<th class="text-right">Turns</th>
					<th class="text-right">Cost</th>
					<th class="text-right">In / Out</th>
					<th>Hit cap</th>
					<th>Note</th>
				</tr>
			</thead>
			<tbody>
				for _, row := range p.Rows {
					@agentRunsRow(row, p.Mode)
				}
			</tbody>
		</table>
	</div>
}

templ agentRunsRow(r AgentRunRowProps, mode string) {
	<tr class="hover:bg-base-200/40">
		<td>
			<a href={ templ.SafeURL(fmt.Sprintf("/agents/runs/%s", r.ShortID)) } class="font-mono text-xs text-primary hover:underline">
				{ r.ShortID }
			</a>
		</td>
		if mode == "global" {
			<td>
				<a href={ templ.SafeURL(fmt.Sprintf("/agents/%s/runs", r.AgentSlug)) } class="hover:underline">
					{ r.AgentName }
				</a>
			</td>
		}
		<td>@agentRunStatusBadge(r.Status)
</td>
		<td><span class="text-xs text-base-content/70">{ r.Trigger }</span></td>
		<td>
			<span class="text-xs tabular-nums" title={ r.StartedAt.Format(time.RFC3339) }>
				{ formatAgentRunStarted(r.StartedAt) }
			</span>
		</td>
		<td class="text-right tabular-nums text-xs">{ formatAgentRunDuration(r.DurationMs) }</td>
		<td class="text-right tabular-nums text-xs">{ strconv.Itoa(r.Turns) }</td>
		<td class="text-right tabular-nums text-xs">{ formatAgentRunCost(r.CostUSD) }</td>
		<td class="text-right tabular-nums text-xs whitespace-nowrap">{ formatAgentRunTokens(r.TokensIn, r.TokensOut) }</td>
		<td>
			if r.HitCap != "" {
				<span class="badge badge-soft badge-warning badge-xs">{ r.HitCap }</span>
			} else {
				<span class="text-xs text-base-content/30">&mdash;</span>
			}
		</td>
		<td class="max-w-[16rem]">
			if r.Note != "" {
				<span class="text-xs text-base-content/60 line-clamp-1" title={ r.Note }>{ truncateAgentRunNote(r.Note, 60) }</span>
			} else {
				<span class="text-xs text-base-content/30">&mdash;</span>
			}
		</td>
	</tr>
}

templ agentRunStatusBadge(status string) {
	switch status {
		case "success":
			<span class="badge badge-soft badge-success badge-sm">success</span>
		case "error":
			<span class="badge badge-soft badge-error badge-sm">error</span>
		case "in_progress":
			<span class="badge badge-soft badge-warning badge-sm gap-1">
				<span class="loading loading-spinner loading-xs"></span>
				running
			</span>
		case "skipped":
			<span class="badge badge-soft badge-neutral badge-sm">skipped</span>
		case "timeout":
			<span class="badge badge-soft badge-error badge-sm">timeout</span>
		default:
			<span class="badge badge-soft badge-sm">{ status }</span>
	}
}

templ agentRunsPagination(p AgentRunsListProps) {
	<div class="bb-paginator">
		<span class="text-xs text-base-content/50 tabular-nums hidden sm:inline">
			{ fmt.Sprintf("Showing %d to %d", p.Offset+1, p.Offset+len(p.Rows)) }
		</span>
		<div class="bb-paginator__nav">
			if p.Offset > 0 {
				<a href={ templ.SafeURL(agentRunsPageHref(p, prevOffset(p.Offset, p.Limit))) } class="bb-paginator__btn" title="Previous page">
					<i data-lucide="chevron-left" class="w-3.5 h-3.5"></i>
					Prev
				</a>
			}
			if len(p.Rows) >= p.Limit {
				<a href={ templ.SafeURL(agentRunsPageHref(p, p.Offset+p.Limit)) } class="bb-paginator__btn" title="Next page">
					Next
					<i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
				</a>
			}
		</div>
	</div>
}

templ agentRunsEmpty(p AgentRunsListProps) {
	@components.EmptyState(components.EmptyStateProps{
		Icon:     "search-x",
		Title:    "No runs match the current filters.",
		CTAHref:  templ.SafeURL(agentRunsFormAction(p)),
		CTALabel: "Clear filters",
		Compact:  true,
		InCard:   true,
	})
}

// AgentRunDetail renders the per-run page: metadata card, operator note,
// transcript. The handler in internal/admin/agent_runs_page.go parses the
// NDJSON transcript file (capped at 500 events; Truncated set when more).
// When the run is in_progress the props include RefreshSeconds so the
// browser meta-refreshes to pull new transcript lines as the sidecar
// writes them. We don't poll-with-fetch because the v1 admin layer
// historically avoids that and meta-refresh is good enough for a
// transcript that grows slowly (each turn is several seconds at minimum).
templ AgentRunDetail(p AgentRunDetailProps) {
	if p.RefreshSeconds > 0 {
		<meta http-equiv="refresh" content={ strconv.Itoa(p.RefreshSeconds) }/>
	}
	@agentRunDetailHeader(p)
	if p.Error != "" {
		<div class="alert alert-error my-4">
			<i data-lucide="alert-triangle" class="w-4 h-4"></i>
			<span>{ p.Error }</span>
		</div>
	}
	@agentRunDetailMetadata(p)
	@agentRunDetailNote(p)
	@agentRunDetailPrompt(p)
	@agentRunDetailTranscript(p)
}

templ agentRunDetailHeader(p AgentRunDetailProps) {
	<div class="bb-page-header">
		<div>
			<div class="text-xs text-base-content/50 mb-1">
				<a href="/agents" class="hover:underline">Agents</a>
				<span class="mx-1">/</span>
				if p.Run.AgentSlug != "" {
					<a href={ templ.SafeURL(fmt.Sprintf("/agents/%s/runs", p.Run.AgentSlug)) } class="hover:underline">
						{ runDetailAgentDisplay(p.Run) }
					</a>
					<span class="mx-1">/</span>
				}
				<a href="/agents/runs" class="hover:underline">Runs</a>
				<span class="mx-1">/</span>
				<span class="font-mono">{ p.Run.ShortID }</span>
			</div>
			<div class="flex items-center gap-3">
				<h1 class="bb-page-title font-mono">{ p.Run.ShortID }</h1>
				@agentRunStatusBadge(p.Run.Status)
				if p.RefreshSeconds > 0 {
					<span class="text-xs text-base-content/40">
						(refreshing every { strconv.Itoa(p.RefreshSeconds) }s)
					</span>
				}
			</div>
		</div>
		<div class="flex items-center gap-2">
			if p.Run.AgentSlug != "" {
				<a href={ templ.SafeURL(fmt.Sprintf("/agents/%s/runs", p.Run.AgentSlug)) } class="btn btn-ghost btn-sm rounded-xl">
					<i data-lucide="arrow-left" class="w-3.5 h-3.5"></i>
					Back to runs
				</a>
			} else {
				<a href="/agents/runs" class="btn btn-ghost btn-sm rounded-xl">
					<i data-lucide="arrow-left" class="w-3.5 h-3.5"></i>
					Back to runs
				</a>
			}
		</div>
	</div>
}

templ agentRunDetailMetadata(p AgentRunDetailProps) {
	<div class="bb-card p-4 mb-4">
		<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 text-xs">
			<div>
				<div class="text-base-content/50 mb-1">Trigger</div>
				<div class="font-medium">{ p.Run.Trigger }</div>
			</div>
			<div>
				<div class="text-base-content/50 mb-1">Started</div>
				<div class="font-medium tabular-nums" title={ p.Run.StartedAt.Format(time.RFC3339) }>{ formatAgentRunStarted(p.Run.StartedAt) }</div>
			</div>
			<div>
				<div class="text-base-content/50 mb-1">Finished</div>
				<div class="font-medium tabular-nums">{ formatAgentRunFinished(p.Run.FinishedAt) }</div>
			</div>
			<div>
				<div class="text-base-content/50 mb-1">Duration</div>
				<div class="font-medium tabular-nums">{ formatAgentRunDuration(p.Run.DurationMs) }</div>
			</div>
			<div>
				<div class="text-base-content/50 mb-1">Cost</div>
				<div class="font-medium tabular-nums">{ formatAgentRunCost(p.Run.CostUSD) }</div>
			</div>
			<div>
				<div class="text-base-content/50 mb-1">Tokens (in / out)</div>
				<div class="font-medium tabular-nums">{ formatAgentRunTokens(p.Run.TokensIn, p.Run.TokensOut) }</div>
			</div>
			<div>
				<div class="text-base-content/50 mb-1">Turns</div>
				<div class="font-medium tabular-nums">{ strconv.Itoa(p.Run.Turns) }</div>
			</div>
			if p.Run.HitCap != "" {
				<div>
					<div class="text-base-content/50 mb-1">Hit cap</div>
					<div><span class="badge badge-soft badge-warning badge-xs">{ p.Run.HitCap }</span></div>
				</div>
			}
		</div>
	</div>
}

templ agentRunDetailNote(p AgentRunDetailProps) {
	<div class="bb-card p-4 mb-4">
		<h2 class="text-sm font-semibold mb-2 flex items-center gap-2">
			<i data-lucide="sticky-note" class="w-4 h-4 text-base-content opacity-60"></i>
			Operator note
		</h2>
		<form method="POST" action={ templ.SafeURL(fmt.Sprintf("/-/agents/runs/%s/note", p.Run.ShortID)) }>
			<input type="hidden" name="csrf_token" value={ p.CSRFToken }/>
			<textarea
				name="note"
				maxlength="2000"
				rows="3"
				placeholder="Add a note about this run..."
				class="textarea textarea-bordered w-full text-sm"
			>{ p.Run.Note }</textarea>
			<div class="flex items-center justify-end mt-2">
				<button type="submit" class="btn btn-sm btn-primary rounded-xl">Save note</button>
			</div>
		</form>
	</div>
}

templ agentRunDetailPrompt(p AgentRunDetailProps) {
	if p.SystemPrompt != "" || p.Prompt != "" || p.PromptPrefix != "" {
		<div class="bb-card p-4 mb-4">
			<h2 class="text-sm font-semibold mb-2 flex items-center gap-2">
				<i data-lucide="message-square" class="w-4 h-4 text-base-content opacity-60"></i>
				Prompt
			</h2>
			if p.PromptPrefix != "" {
				<details class="mb-2">
					<summary class="cursor-pointer text-xs text-base-content/60 hover:text-base-content">Per-run prefix</summary>
					<pre class="mt-2 text-xs whitespace-pre-wrap bg-base-200/50 rounded p-3 font-mono">{ p.PromptPrefix }</pre>
				</details>
			}
			if p.SystemPrompt != "" {
				<details class="mb-2">
					<summary class="cursor-pointer text-xs text-base-content/60 hover:text-base-content">System prompt</summary>
					<pre class="mt-2 text-xs whitespace-pre-wrap bg-base-200/50 rounded p-3 font-mono">{ p.SystemPrompt }</pre>
				</details>
			}
			if p.Prompt != "" {
				<details>
					<summary class="cursor-pointer text-xs text-base-content/60 hover:text-base-content">User prompt</summary>
					<pre class="mt-2 text-xs whitespace-pre-wrap bg-base-200/50 rounded p-3 font-mono">{ p.Prompt }</pre>
				</details>
			}
		</div>
	}
}

templ agentRunDetailTranscript(p AgentRunDetailProps) {
	<div class="bb-card p-4">
		<div class="flex items-center justify-between mb-3">
			<h2 class="text-sm font-semibold flex items-center gap-2">
				<i data-lucide="scroll-text" class="w-4 h-4 text-base-content opacity-60"></i>
				Transcript
			</h2>
			if len(p.Transcript) > 0 {
				<span class="text-xs text-base-content/40 tabular-nums">{ strconv.Itoa(len(p.Transcript)) } events</span>
			}
		</div>
		if p.Truncated {
			<div class="alert alert-warning alert-soft mb-3 text-xs">
				<i data-lucide="alert-triangle" class="w-4 h-4"></i>
				<span>
					Showing first 500 events. Raw transcript at <code class="font-mono text-[0.7rem]">{ p.TranscriptPath }</code>.
				</span>
			</div>
		}
		if len(p.Transcript) == 0 {
			if p.Run.Status == "in_progress" {
				<p class="text-sm text-base-content/50 italic">Transcript will appear here as the run progresses.</p>
			} else {
				<p class="text-sm text-base-content/50 italic">Transcript will appear here when the run completes.</p>
			}
		} else {
			<div class="space-y-3">
				for i, ev := range p.Transcript {
					@agentRunTranscriptEvent(ev, i)
				}
			</div>
		}
	</div>
}

templ agentRunTranscriptEvent(ev TranscriptEvent, idx int) {
	switch ev.Type {
		case "assistant":
			<div class="border-l-2 border-primary/40 pl-3">
				<div class="text-[0.65rem] uppercase tracking-wider text-primary/70 mb-1">Assistant</div>
				if ev.Text != "" {
					<div class="text-sm whitespace-pre-wrap">{ ev.Text }</div>
				} else {
					<div class="text-xs text-base-content/40 italic">(no text content)</div>
				}
			</div>
		case "user":
			<div class="border-l-2 border-base-content/20 pl-3">
				<div class="text-[0.65rem] uppercase tracking-wider text-base-content/50 mb-1">User</div>
				if ev.Text != "" {
					<div class="text-sm whitespace-pre-wrap">{ ev.Text }</div>
				} else {
					<div class="text-xs text-base-content/40 italic">(tool results returned)</div>
				}
			</div>
		case "tool_use":
			<details class="border-l-2 border-info/40 pl-3">
				<summary class="cursor-pointer">
					<span class="text-[0.65rem] uppercase tracking-wider text-info/70 mr-2">Tool use</span>
					<span class="font-mono text-xs">{ ev.ToolName }</span>
				</summary>
				if ev.ToolInputJSON != "" {
					<pre class="mt-2 text-xs bg-base-200/50 rounded p-2 font-mono whitespace-pre-wrap overflow-x-auto">{ ev.ToolInputJSON }</pre>
				}
			</details>
		case "tool_result":
			<details class="border-l-2 border-info/20 pl-3">
				<summary class="cursor-pointer">
					<span class="text-[0.65rem] uppercase tracking-wider text-info/60 mr-2">Tool result</span>
				</summary>
				if ev.ToolResultJSON != "" {
					<pre class="mt-2 text-xs bg-base-200/50 rounded p-2 font-mono whitespace-pre-wrap overflow-x-auto">{ ev.ToolResultJSON }</pre>
				}
			</details>
		case "result":
			<div class="bb-card bg-base-200/40 p-3">
				<div class="text-[0.65rem] uppercase tracking-wider text-base-content/60 mb-2">Final result</div>
				<div class="grid grid-cols-2 sm:grid-cols-5 gap-3 text-xs">
					<div>
						<div class="text-base-content/50">Cost</div>
						<div class="font-medium tabular-nums">{ formatAgentRunCost(ev.CostUSD) }</div>
					</div>
					<div>
						<div class="text-base-content/50">Tokens in</div>
						<div class="font-medium tabular-nums">{ strconv.FormatInt(ev.TokensIn, 10) }</div>
					</div>
					<div>
						<div class="text-base-content/50">Tokens out</div>
						<div class="font-medium tabular-nums">{ strconv.FormatInt(ev.TokensOut, 10) }</div>
					</div>
					<div>
						<div class="text-base-content/50">Cache read</div>
						<div class="font-medium tabular-nums">{ strconv.FormatInt(ev.CacheRead, 10) }</div>
					</div>
					<div>
						<div class="text-base-content/50">Cache write</div>
						<div class="font-medium tabular-nums">{ strconv.FormatInt(ev.CacheWrite, 10) }</div>
					</div>
				</div>
			</div>
		case "error":
			<div class="alert alert-error alert-soft text-xs">
				<i data-lucide="alert-circle" class="w-4 h-4"></i>
				<div>
					<div class="font-medium">Error</div>
					<div class="text-base-content/70">{ ev.Text }</div>
				</div>
			</div>
		default:
			<details class="border-l-2 border-base-content/10 pl-3">
				<summary class="cursor-pointer text-xs text-base-content/50">
					Raw event
					if ev.Type != "" {
						<span class="ml-2 font-mono">{ ev.Type }</span>
					}
				</summary>
				<pre class="mt-2 text-xs bg-base-200/50 rounded p-2 font-mono whitespace-pre-wrap overflow-x-auto">{ ev.RawJSON }</pre>
			</details>
	}
}

// ====================================================================
// Helpers
// ====================================================================

// agentRunsFormAction returns the URL the filter form posts to. Per-agent
// pages stay scoped to /agents/{slug}/runs so Apply preserves the agent
// scope; the global page lives at /agents/runs.
func agentRunsFormAction(p AgentRunsListProps) string {
	if p.Mode == "agent" && p.AgentSlug != "" {
		return "/agents/" + p.AgentSlug + "/runs"
	}
	return "/agents/runs"
}

// agentRunsPageHref builds a paging URL preserving the current filter set
// and swapping in the new offset. Kept lightweight (manual encode) so we
// don't need url.Values from the templ side.
func agentRunsPageHref(p AgentRunsListProps, offset int) string {
	base := agentRunsFormAction(p)
	q := ""
	add := func(k, v string) {
		if v == "" {
			return
		}
		if q == "" {
			q = "?"
		} else {
			q += "&"
		}
		q += k + "=" + v
	}
	if p.Mode == "global" {
		add("agent", p.Filters.AgentSlug)
	}
	add("status", p.Filters.Status)
	add("trigger", p.Filters.Trigger)
	add("hit_cap", p.Filters.HitCap)
	add("start", p.Filters.Start)
	add("end", p.Filters.End)
	if p.Limit > 0 {
		add("limit", strconv.Itoa(p.Limit))
	}
	add("offset", strconv.Itoa(offset))
	return base + q
}

func prevOffset(current, limit int) int {
	v := current - limit
	if v < 0 {
		return 0
	}
	return v
}

// formatAgentRunStarted returns a compact "Jan 02 15:04" timestamp. We
// don't have access to the relativeTime helper here (admin package), so a
// fixed format is fine for an admin table.
func formatAgentRunStarted(t time.Time) string {
	if t.IsZero() {
		return "—"
	}
	return t.Format("Jan 02 15:04")
}

func formatAgentRunFinished(t *time.Time) string {
	if t == nil || t.IsZero() {
		return "—"
	}
	return t.Format("Jan 02 15:04")
}

func formatAgentRunDuration(ms int64) string {
	if ms <= 0 {
		return "—"
	}
	if ms < 1000 {
		return fmt.Sprintf("%dms", ms)
	}
	secs := float64(ms) / 1000.0
	if secs < 60 {
		return fmt.Sprintf("%.1fs", secs)
	}
	mins := secs / 60.0
	return fmt.Sprintf("%.1fm", mins)
}

func formatAgentRunCost(v float64) string {
	if v <= 0 {
		return "—"
	}
	return fmt.Sprintf("$%.4f", v)
}

func formatAgentRunTokens(in, out int64) string {
	if in == 0 && out == 0 {
		return "—"
	}
	return fmt.Sprintf("%d / %d", in, out)
}

func truncateAgentRunNote(s string, n int) string {
	if len(s) <= n {
		return s
	}
	return s[:n] + "…"
}

func runDetailAgentDisplay(r AgentRunRowProps) string {
	if r.AgentName != "" {
		return r.AgentName
	}
	return r.AgentSlug
}
