# Breadbox Production Configuration
# Copy to .env and fill in the values.

# --- Domain ---
# Your domain name for automatic HTTPS via Let's Encrypt
DOMAIN=example.com

# --- Database ---
DATABASE_URL=postgres://breadbox:CHANGE_ME@db:5432/breadbox?sslmode=disable

# --- Security ---
# 32-byte encryption key as 64-character hex string.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# --- Server ---
SERVER_PORT=8080
ENVIRONMENT=docker

# --- Plaid (optional) ---
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox

# --- Teller (optional) ---
# TELLER_APP_ID=
# TELLER_CERT_PATH=
# TELLER_KEY_PATH=
# TELLER_ENV=sandbox
# TELLER_WEBHOOK_SECRET=

# --- Docker Compose (used by db service) ---
POSTGRES_USER=breadbox
# IMPORTANT: Generate a strong password: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=breadbox
