{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "lib": ["ES2022"],
    "types": ["bun-types"]
  },
  "include": ["index.ts", "spec.ts", "events.ts"],
  "exclude": ["node_modules", "dist", "bin"]
}
